# arbstr node environment variables
# Copy to .env and fill in values: cp .env.example .env

# Vault operator admin token (min 32 chars, required)
VAULT_ADMIN_TOKEN=change-me-to-a-random-admin-secret

# Vault internal API shared secret (shared between core and vault)
VAULT_INTERNAL_TOKEN=change-me-to-a-random-internal-secret

# Cashu mint private key (auto-generated if not set)
MINT_PRIVATE_KEY=supersecretprivatekey

# Cashu payment rail threshold in millisatoshis (default: 1M msats = 1000 sats)
# Below threshold: Cashu (instant, zero fees). Above: Lightning (final settlement).
CASHU_THRESHOLD_MSAT=1000000

# LND credentials (base64-encoded, required for mainnet)
# LND_CERT_BASE64=
# LND_MACAROON_BASE64=

# Logging level for arbstr core
RUST_LOG=arbstr=info
